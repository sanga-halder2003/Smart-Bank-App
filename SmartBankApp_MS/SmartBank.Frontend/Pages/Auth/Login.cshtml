@page
@model SmartBank.Frontend.Pages.Auth.LoginModel

@{
    ViewData["Title"] = "Login";
}

<h2 class="mb-4">Smart Bank Login</h2>

<form method="post">

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="LoginRequest.Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input asp-for="LoginRequest.Password"
               type="password"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Login
    </button>

</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info mt-3">
        @Model.Message
    </div>
}