@page
@model SmartBank.Frontend.Pages.Auth.RegisterModel

@{
    ViewData["Title"] = "Register";
}

<h2 class="mb-4">Customer Registration</h2>

<form method="post">

    <div class="mb-3">
        <label>Full Name</label>
        <input asp-for="RegisterRequest.FullName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="RegisterRequest.Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input asp-for="RegisterRequest.Password"
               type="password"
               class="form-control" />
    </div>

    <button class="btn btn-success">
        Register
    </button>

</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info mt-3">
        @Model.Message
    </div>
}